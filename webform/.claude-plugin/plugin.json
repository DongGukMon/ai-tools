{
  "name": "webform",
  "version": "v2.1.0",
  "description": "Dynamic browser form for collecting structured user input in Claude Code sessions",
  "author": {
    "name": "Airen Kang",
    "url": "https://github.com/bang9"
  },
  "repository": "https://github.com/bang9/ai-tools",
  "license": "MIT",
  "keywords": [
    "form",
    "browser",
    "input",
    "structured-data",
    "collection"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-binary.sh"
          }
        ]
      }
    ]
  }
}
