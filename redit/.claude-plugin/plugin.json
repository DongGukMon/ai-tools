{
  "name": "redit",
  "version": "v1.22.0",
  "description": "Remote Edit Layer - Local cache for efficiently editing remote documents",
  "author": {
    "name": "Airen Kang",
    "url": "https://github.com/bang9"
  },
  "repository": "https://github.com/bang9/ai-tools",
  "license": "MIT",
  "keywords": [
    "remote",
    "edit",
    "cache",
    "document",
    "confluence",
    "notion"
  ],
  "category": "productivity",
  "skills": "./skills/",
  "mcpServers": "./.mcp.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-binary.sh"
          }
        ]
      }
    ]
  }
}
