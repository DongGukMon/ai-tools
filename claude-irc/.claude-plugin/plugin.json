{
  "name": "claude-irc",
  "version": "v1.34.1",
  "description": "IRC-inspired inter-session communication for Claude Code agents",
  "author": {
    "name": "Airen Kang",
    "url": "https://github.com/bang9"
  },
  "repository": "https://github.com/bang9/ai-tools",
  "license": "MIT",
  "keywords": [
    "irc",
    "communication",
    "agent",
    "inter-session",
    "collaboration"
  ],
  "skills": "./skills/",
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-binary.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-irc quit 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
