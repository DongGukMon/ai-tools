{
  "name": "whip",
  "version": "v2.11.0",
  "description": "Task orchestrator for Claude Code — spawn and manage multiple task sessions",
  "author": {
    "name": "Airen Kang",
    "url": "https://github.com/bang9"
  },
  "repository": "https://github.com/bang9/ai-tools",
  "license": "MIT",
  "keywords": [
    "task",
    "orchestrator",
    "parallel",
    "session",
    "management"
  ],
  "skills": "./skills/",
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-binary.sh"
          }
        ]
      }
    ]
  }
}
